{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "collective notify check --stdin --dm-only --xml",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "collective notify check --stdin --dm-only --xml",
            "type": "command"
          }
        ],
        "matcher": "Edit|Write|Read"
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "collective activity available --stdin 2>/dev/null || true",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "collective activity active --stdin 2>/dev/null || true",
            "type": "command"
          }
        ],
        "matcher": ""
      },
      {
        "hooks": [
          {
            "command": "meridian member activity active --stdin 2>/dev/null || true",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "collective notify check --stdin --xml",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "collective notify summary --stdin --quiet --xml 2>/dev/null || true",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  },
  "additionalDirectories": ["/Users/tom/Developer/projects/deno_rust/meridian"]
}
