{
  "design_system": "yggdrasil-briefs",
  "version": "0.1.0",
  "scope": "private",
  "profiles": ["codebase-explorer", "workflow-developer", "hardener", "reviewer"],
  "input": {
    "type": "object",
    "properties": {
      "brief": {
        "type": "string",
        "description": "Brief JSON (schema: .meridian/design-system/schemas/brief.schema.json)."
      },
      "design_content": {
        "type": "string",
        "description": "Design document content."
      },
      "checklist_content": {
        "type": "string",
        "description": "Checklist JSON content for C-number resolution."
      },
      "stories_content": {
        "type": "string",
        "description": "Stories JSON content for S-number resolution."
      },
      "notify": {
        "type": "string",
        "description": "Member name to notify on completion."
      }
    },
    "required": ["brief"]
  },
  "trigger": {
    "kind": "manual"
  }
}
