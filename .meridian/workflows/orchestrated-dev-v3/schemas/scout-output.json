{
  "type": "object",
  "properties": {
    "summary": {"type": "string", "description": "2-3 sentences orienting the implementer."},
    "enrichments": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {"type": "string", "description": "R# id from the brief"},
          "related_files": {"type": "array", "items": {"type": "string"}, "description": "Existing files relevant to this R# (path + brief note on why)"},
          "context": {"type": "array", "items": {"type": "string"}, "description": "Key findings: sibling conventions, type signatures, module layout"},
          "references": {"type": "array", "items": {"type": "string"}, "description": "Files to reference during implementation (path:line-range)"}
        },
        "required": ["id", "related_files", "context", "references"]
      }
    }
  },
  "required": ["summary", "enrichments"]
}
