{
  "type": "object",
  "properties": {
    "summary": {"type": "string", "description": "1-2 sentences on what was done."},
    "commit_message": {"type": "string", "description": "Conventional-commits style."},
    "enrichments": {
      "type": "array",
      "description": "One entry per R# — how it was implemented.",
      "items": {
        "type": "object",
        "properties": {
          "id": {"type": "string", "description": "R# id"},
          "status": {"type": "string", "enum": ["implemented", "blocked"]},
          "files_changed": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "path": {"type": "string"},
                "change": {"type": "string", "enum": ["created", "modified", "deleted"]},
                "note": {"type": "string"}
              },
              "required": ["path", "change", "note"]
            }
          },
          "how_satisfied": {"type": "string", "description": "How this requirement was met."},
          "deviation": {"type": "string", "description": "Empty if followed plan. Otherwise: what changed and why."},
          "checklist_status": {"type": "array", "items": {"type": "object", "properties": {"id": {"type": "string"}, "done": {"type": "boolean"}, "note": {"type": "string"}}, "required": ["id", "done", "note"]}},
          "stories_status": {"type": "array", "items": {"type": "object", "properties": {"id": {"type": "string"}, "satisfied": {"type": "boolean"}, "note": {"type": "string"}}, "required": ["id", "satisfied", "note"]}}
        },
        "required": ["id", "status", "files_changed", "how_satisfied", "deviation", "checklist_status", "stories_status"]
      }
    },
    "attestation": {
      "type": "object",
      "description": "Behavior bond — certify clean implementation.",
      "properties": {
        "no_panics": {"type": "boolean", "description": "No unwrap/expect/panic/todo in library code."},
        "no_unsafe": {"type": "boolean", "description": "No unsafe blocks added."},
        "boundaries_respected": {"type": "boolean", "description": "All SHALL NOT boundaries observed."},
        "tests_considered": {"type": "boolean", "description": "Tests added or existing tests still pass."}
      },
      "required": ["no_panics", "no_unsafe", "boundaries_respected", "tests_considered"]
    }
  },
  "required": ["summary", "commit_message", "enrichments", "attestation"]
}
