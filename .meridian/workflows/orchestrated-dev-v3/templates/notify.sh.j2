MEMBER="{{ input.notify | shell_escape }}"
if [ -n "$MEMBER" ]; then
  RUN_NAME="{{ input['run-name'] | shell_escape if input['run-name'] else '' }}"
  BRIEF_ID="{{ input.brief.id | shell_escape }}"
  MSG_FILE=$(mktemp)
  cat > "$MSG_FILE" <<'__YGG_NOTIFY_MSG__'
orchestrated-dev-v3 complete: {{ input.brief.id }} — {{ input.brief.title }}
{% if dev.summary %}Dev: {{ dev.summary }}{% endif %}
{% if harden.summary %}Harden: {{ harden.summary }}{% endif %}
{% if review.summary %}Review: {{ review.summary }}{% endif %}
__YGG_NOTIFY_MSG__
  MSG=$(cat "$MSG_FILE")
  rm -f "$MSG_FILE"
  collective send --as "Meridian" --to "$MEMBER" --subject "workflow complete: ${RUN_NAME:-$BRIEF_ID}" --message "$MSG" || true
fi
echo "Done"
